{
  "format_version": "1.8.0",
  "animations": {
    "animation.npc.idle": {
      "loop": true,
      "animation_length": 2.0,
      "bones": {
        "head": {
          "rotation": ["math.sin(query.anim_time * 60) * 2", 0, 0]
        },
        "left_arm": {
          "rotation": [0, 0, "math.sin(query.anim_time * 45) * 1.5"]
        },
        "right_arm": {
          "rotation": [0, 0, "-math.sin(query.anim_time * 45) * 1.5"]
        }
      }
    },
    "animation.npc.walk": {
      "loop": true,
      "animation_length": 1.0,
      "bones": {
        "right_leg": {
          "rotation": ["math.sin(query.anim_time * 360) * 25", 0, 0]
        },
        "left_leg": {
          "rotation": ["-math.sin(query.anim_time * 360) * 25", 0, 0]
        },
        "left_arm": {
          "rotation": ["-math.sin(query.anim_time * 360) * 25", 0, 0]
        },
        "right_arm": {
          "rotation": ["math.sin(query.anim_time * 360) * 25", 0, 0]
        }
      }
    }
  }
}
