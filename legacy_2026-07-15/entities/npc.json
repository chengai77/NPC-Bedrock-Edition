{
  "format_version": "1.26.10",
  "minecraft:entity": {
    "description": {
      "identifier": "customnpc:npc",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false,
      "properties": {
        "customnpc:skin_id": {
          "type": "int",
          "range": [1, 100],
          "default": 1,
          "client_sync": true
        },
        "customnpc:arm_model": {
          "type": "int",
          "range": [0, 1],
          "default": 0,
          "client_sync": true
        }
      }
    },
    "components": {
