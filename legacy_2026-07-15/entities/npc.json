        "family": ["customnpc", "npc", "mob"]
      },
      "minecraft:health": {
        "value": 20,
        "max": 20
      },
      "minecraft:movement": {
        "value": 0.0
      },
      "minecraft:physics": {
        "has_gravity": true,
        "has_collision": true
      },
      "minecraft:collision_box": {
        "width": 0.6,
        "height": 1.8
      },
      "minecraft:knockback_resistance": {
        "value": 1.0,
        "max": 1.0
      },
      "minecraft:interact": {
        "interactions": [
          {
            "interact_text": "action.interact.talk",
            "use_item": false,
            "swing": false
          }
        ]
      }
    }
  }
}